        {
          "name": "Worker-1 Polls Inbox — Sees Two TaskAssigned",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('List notifications returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Response is an array', function () {",
                  "    pm.expect(body).to.be.an('array');",
                  "});",
                  "",
                  "const taskAId = pm.collectionVariables.get('taskAId');",
                  "const taskCId = pm.collectionVariables.get('taskCId');",
                  "",
                  "const assignedForA = body.find(n => n.type === 'TaskAssigned' && n.taskId === taskAId);",
                  "const assignedForC = body.find(n => n.type === 'TaskAssigned' && n.taskId === taskCId);",
                  "",
                  "pm.test('TaskAssigned for Task A is present with task title joined', function () {",
                  "    pm.expect(assignedForA, 'TaskAssigned for Task A').to.be.an('object');",
                  "    pm.expect(assignedForA.taskTitle).to.eql('Setup Auth');",
                  "    pm.expect(assignedForA.message).to.include(\"Setup Auth\");",
                  "    pm.expect(assignedForA.isAcknowledged).to.eql(false);",
                  "    pm.expect(assignedForA.id).to.be.a('string').and.not.empty;",
                  "    pm.expect(assignedForA.createdAt).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('TaskAssigned for Task C is present', function () {",
                  "    pm.expect(assignedForC, 'TaskAssigned for Task C').to.be.an('object');",
                  "    pm.expect(assignedForC.taskTitle).to.eql('Refactor Module');",
                  "});",
                  "",
                  "pm.test('Notifications are ordered by createdAt descending', function () {",
                  "    for (let i = 0; i < body.length - 1; i++) {",
                  "        pm.expect(new Date(body[i].createdAt).getTime())",
                  "            .to.be.at.least(new Date(body[i + 1].createdAt).getTime());",
                  "    }",
                  "});",
                  "",
                  "// Capture the older TaskAssigned id (Task A) for the Acknowledge test later.",
                  "pm.collectionVariables.set('worker1AssignedNotificationId', assignedForA.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Api-Key", "value": "{{worker1ApiKey}}", "type": "text" }
            ],
