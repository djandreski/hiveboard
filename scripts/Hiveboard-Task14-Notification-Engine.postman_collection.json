              "raw": "{{baseUrl}}/api/v1/agents/me/notifications/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "agents", "me", "notifications", ""]
            },
            "description": "AC1 — polling. AC3 — TaskAssigned scenario. Verifies the response shape (id, type, taskId, taskTitle, message, createdAt, isAcknowledged) and descending ordering."
          },
          "response": []
        }
      ]
