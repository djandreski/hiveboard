        {
          "name": "List Project Decisions",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('List decisions returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const decisionIds = body.map(function (decision) { return decision.id; });",
                  "const timestamps = body.map(function (decision) { return Date.parse(decision.createdAt); });",
                  "",
                  "pm.test('Exactly three decisions exist for the isolated project', function () {",
                  "    pm.expect(body).to.be.an('array').with.lengthOf(3);",
                  "});",
                  "",
                  "pm.test('All created decisions are present', function () {",
                  "    pm.expect(decisionIds).to.include(pm.collectionVariables.get('linkedDecisionId'));",
                  "    pm.expect(decisionIds).to.include(pm.collectionVariables.get('standaloneDecisionId'));",
                  "    pm.expect(decisionIds).to.include(pm.collectionVariables.get('acceptedTaskDecisionId'));",
                  "});",
                  "",
                  "pm.test('Decision list is sorted newest first', function () {",
                  "    for (let i = 1; i < timestamps.length; i += 1) {",
                  "        pm.expect(timestamps[i - 1]).to.be.at.least(timestamps[i]);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
