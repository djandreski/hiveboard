          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('List notes returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test('Exactly two notes exist for the isolated task', function () {",
                  "    pm.expect(body).to.be.an('array').with.lengthOf(2);",
                  "});",
                  "",
                  "pm.test('Notes are returned in creation order', function () {",
                  "    pm.expect(body[0].id).to.eql(pm.collectionVariables.get('workerNoteId'));",
                  "    pm.expect(body[1].id).to.eql(pm.collectionVariables.get('coordinatorNoteId'));",
                  "});",
                  "",
                  "pm.test('Each note includes author metadata', function () {",
                  "    body.forEach(function (note) {",
                  "        pm.expect(note.agentName).to.be.a('string').and.not.empty;",
                  "        pm.expect(note.agentType).to.be.a('string').and.not.empty;",
                  "    });",
                  "});"
                ]
              }
            }
