        {
          "name": "Get Task Context And Verify note_added Events",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Task context returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const noteEvents = body.events.filter(function (taskEvent) {",
                  "    return taskEvent.eventType === 'note_added';",
                  "});",
                  "const eventTypes = noteEvents.map(function (taskEvent) {",
                  "    return taskEvent.newValue;",
                  "});",
                  "",
                  "pm.test('A note_added event exists for each created note', function () {",
                  "    pm.expect(noteEvents).to.have.lengthOf(2);",
                  "});",
                  "",
                  "pm.test('Recorded note types match the created notes', function () {",
                  "    pm.expect(eventTypes).to.include('context');",
                  "    pm.expect(eventTypes).to.include('reviewrequest');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Api-Key",
                "value": "{{worker1ApiKey}}",
                "type": "text"
              }
            ],
