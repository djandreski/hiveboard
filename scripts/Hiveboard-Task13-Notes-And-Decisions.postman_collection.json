                  "pm.test('Worker note is attributed correctly', function () {",
                  "    pm.expect(body.taskId).to.eql(pm.collectionVariables.get('taskId'));",
                  "    pm.expect(body.agentName).to.eql('Worker-1');",
                  "    pm.expect(body.agentType).to.eql('worker');",
                  "    pm.expect(body.noteType).to.eql('context');",
                  "});",
