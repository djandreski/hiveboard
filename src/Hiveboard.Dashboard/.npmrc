# Project-local npm config.
#
# This explicitly clears any `os` / `cpu` overrides inherited from a
# user-level ~/.npmrc so Rollup's per-platform native bindings (and
# anyone else's platform-conditioned optional deps) resolve to the
# actual host instead of a forced platform. Without this, machines
# with `os=linux` in their user .npmrc end up missing
# `@rollup/rollup-win32-x64-msvc` on Windows and the build fails with
# "Cannot find native binding" — see
# https://github.com/npm/cli/issues/4828.
os=
cpu=
