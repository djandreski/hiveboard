{
  "name": "hiveboard-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "//": "optionalDependencies pin Rollup's per-platform native bindings to work around npm/cli#4828, which otherwise fails to install them on Windows + Node 23 ('Cannot find module @rollup/rollup-win32-x64-msvc'). npm picks only the binding matching the current OS/CPU; the rest are skipped automatically.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:bundle": "tsc -b && vite build --base=/dashboard/ --outDir dist-bundle",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.1.5"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.60.3",
    "@rollup/rollup-darwin-x64": "^4.60.3",
    "@rollup/rollup-linux-arm64-gnu": "^4.60.3",
    "@rollup/rollup-linux-arm64-musl": "^4.60.3",
    "@rollup/rollup-linux-x64-gnu": "^4.60.3",
    "@rollup/rollup-linux-x64-musl": "^4.60.3",
    "@rollup/rollup-win32-arm64-msvc": "^4.60.3",
    "@rollup/rollup-win32-x64-msvc": "^4.60.3"
  }
}
